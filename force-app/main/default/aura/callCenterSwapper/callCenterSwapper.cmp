<aura:component implements="force:lightningQuickAction" controller="CallCenterSwapperController">
    <aura:attribute name="callCenters" type="Map" />
    <aura:attribute name="currentCallCenterId" type="String" />
    <aura:attribute name="currentCallCenterName" type="String" />
    <aura:attribute name="isToggled" type="Boolean" default="false" />
    <aura:attribute name="demoCallCenterId" type="String" />
    <aura:attribute name="puzzelCallCenterId" type="String" />
    <aura:attribute name="errorMessage" type="String" />
    <aura:attribute name="isDisabled" type="Boolean" default="false" />
    <aura:attribute name="isUnrecognizedCenter" type="Boolean" default="false" />
    <aura:handler name="init" value="{!this}" action="{!c.init}" />

    <aura:if isTrue="{!v.errorMessage}">
        <div style="display: flex; flex-direction: column; align-items: center; padding: 20px">
            <div style="color: #c23030; font-weight: 500; text-align: center; max-width: 300px">{!v.errorMessage}</div>
        </div>
        <aura:set attribute="else">
            <aura:if isTrue="{!v.isUnrecognizedCenter}">
                <div style="display: flex; flex-direction: column; align-items: center; padding: 20px">
                    <p style="margin: 0 0 20px 0; font-weight: 500">
                        Current Call Center: <strong>{!v.currentCallCenterName}</strong>
                    </p>
                    <div style="display: flex; gap: 10px">
                        <lightning:button label="Switch to Demo" onclick="{!c.handleSwitchToDemo}" variant="brand" />
                        <lightning:button
                            label="Switch to Puzzel"
                            onclick="{!c.handleSwitchToPuzzel}"
                            variant="brand"
                        />
                    </div>
                </div>
                <aura:set attribute="else">
                    <div style="display: flex; flex-direction: column; align-items: center; padding: 20px">
                        <div
                            style="
                                display: flex;
                                justify-content: space-around;
                                width: 200px;
                                margin-bottom: 15px;
                                gap: 20px;
                            "
                        >
                            <p
                                style="{!'margin: 0; font-weight: ' + (v.isToggled ? '500; color: #999' : '700; color: #0070d2; font-size: 16px')}"
                            >
                                Demo
                            </p>
                            <p
                                style="{!'margin: 0; font-weight: ' + (v.isToggled ? '700; color: #0070d2; font-size: 16px' : '500; color: #999')}"
                            >
                                Puzzel
                            </p>
                        </div>
                        <lightning:input
                            name="callCenterToggle"
                            type="toggle"
                            checked="{!v.isToggled}"
                            onchange="{!c.handleToggleChanged}"
                            variant="label-hidden"
                            disabled="{!v.isDisabled}"
                        />
                    </div>
                </aura:set>
            </aura:if>
        </aura:set>
    </aura:if>
</aura:component>
